VITE_SHEETS_API_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_APPS_SCRIPT_DEPLOYMENT/exec
VITE_BACK4APP_APP_ID=your_back4app_application_id
VITE_BACK4APP_JS_KEY=your_back4app_javascript_key
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com

# Auto-fill assignee dropdown (no master key): create class StaffDirectory in Back4App:
#   Database → + Class → StaffDirectory
#   Add: username (String), roles (Array)
#   Class permissions (Security): Authenticated — enable Get, Find, Count; Create; Update
#   (Public read relies on each row’s ACL — the app sets ACL read * on create.)
# After each social worker registers/signs in once, their username appears for admins.
# To use another class name: VITE_STAFF_DIRECTORY_CLASS=YourClassName
# To turn off: VITE_STAFF_DIRECTORY_CLASS=0

# Referral summaries for "Recent Contacts / Clients" list (stored in Back4App, while full record stays in Sheets).
# Create class ReferralSummary with fields:
#   clientName (String), recordType (String), role (String), riskLevel (String), referralAgency (String),
#   recordStatus (String), assignedTo (String), assignedToUsername (String), assignedToUser (Pointer<_User>),
#   lastModifiedBy (String), source (String)
# Class permissions (Security): Authenticated -> Get, Find, Count, Create, Update (Update needed for auto-inactive)
# Optional custom class name:
# VITE_REFERRAL_SUMMARY_CLASS=ReferralSummary
#
# Auto-inactive rule (single shared row):
#   OrgSettings: singletonKey (String, use "default"), inactiveAfterDays (Number, 0 = off)
#   Authenticated: Get, Find, Create, Update
# VITE_ORG_SETTINGS_CLASS=OrgSettings

# Time logging (Back4App):
#   TimeCategory: name (String), sortOrder (Number)
#   TimeLog: user (Pointer<_User>), workDate (Date), durationMinutes (Number),
#            categories (Array of Pointers → TimeCategory), notes (String)
#   Authenticated: Get, Find, Count, Create (and Update/Delete on TimeCategory for edits)
# Defaults seed on first load: Mental Health Help, Hazardous, Establishing contact, Career Counseling
# VITE_TIME_CATEGORY_CLASS=TimeCategory
# VITE_TIME_LOG_CLASS=TimeLog

# Optional extra names (comma-separated) merged into the dropdown.
# VITE_ASSIGNEE_USERNAMES=alice,bob,carol

# Optional: Netlify Function listing _User with BACK4APP_MASTER_KEY (Site env, never VITE_*).
# VITE_STAFF_USERS_URL=http://localhost:8888/.netlify/functions/staff-users
