VITE_SHEETS_API_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_APPS_SCRIPT_DEPLOYMENT/exec
VITE_BACK4APP_APP_ID=your_back4app_application_id
VITE_BACK4APP_JS_KEY=your_back4app_javascript_key
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com
# Optional: comma-separated usernames for "Assign client to" when Back4App user list is restricted (admins only)
# VITE_ASSIGNEE_USERNAMES=alice,bob,carol
#
# Staff dropdown (admins): browser Parse queries only see your own _User row (ACL). List everyone via Netlify Function:
# In Netlify → Site → Environment: BACK4APP_APP_ID, BACK4APP_JS_KEY, BACK4APP_SERVER_URL, BACK4APP_MASTER_KEY (never VITE_*).
# Local with `netlify dev`: optional override, e.g. VITE_STAFF_USERS_URL=http://localhost:8888/.netlify/functions/staff-users
# VITE_STAFF_USERS_URL=
